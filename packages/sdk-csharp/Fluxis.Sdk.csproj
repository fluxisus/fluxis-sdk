<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;netstandard2.1</TargetFrameworks>
    <RootNamespace>Fluxis</RootNamespace>
    <AssemblyName>Fluxis.Sdk</AssemblyName>
    <LangVersion>12</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>

    <!-- NuGet metadata -->
    <PackageId>Fluxis.Sdk</PackageId>
    <Version>0.1.0</Version>
    <Authors>Fluxis</Authors>
    <Description>Official C# SDK for the Fluxis crypto payment processing API</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/fluxisus/fluxis-sdk</PackageProjectUrl>
    <RepositoryUrl>https://github.com/fluxisus/fluxis-sdk</RepositoryUrl>
    <PackageTags>fluxis;crypto;payments;naspip;sdk;blockchain</PackageTags>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Text.Json" Version="8.*" />
  </ItemGroup>

</Project>
