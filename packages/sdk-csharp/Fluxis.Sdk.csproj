<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net6.0</TargetFrameworks>
    <RootNamespace>Fluxis</RootNamespace>
    <AssemblyName>Fluxis.Sdk</AssemblyName>
    <LangVersion>12</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>

    <!-- NuGet metadata -->
    <PackageId>Fluxis.Sdk</PackageId>
    <Version>0.2.0</Version>
    <Authors>Fluxis</Authors>
    <Description>Official C# SDK for the Fluxis crypto payment processing API</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/fluxisus/fluxis-sdk</PackageProjectUrl>
    <RepositoryUrl>https://github.com/fluxisus/fluxis-sdk</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>fluxis;crypto;payments;naspip;sdk;blockchain</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>icon.png</PackageIcon>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="tests/**"/>
    <Compile Remove="examples/**"/>
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/"/>
    <None Include="icon.png" Pack="true" PackagePath="/" Condition="Exists('icon.png')"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Text.Json" Version="8.*"/>
  </ItemGroup>

</Project>
